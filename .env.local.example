# ReUp v2 — local environment configuration
# Copy this file to .env.local and fill in your real DASHSCOPE_API_KEY.

# ---- LLM (Required) ----
# Alibaba DashScope (Bailian) OpenAI-compatible mode.
# Get one from https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-replace-me

# ---- LLM (Optional — defaults shown) ----
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
DASHSCOPE_CHAT_MODEL=gui-plus-2026-02-26
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
LLM_PROVIDER=dashscope

# ---- Resume Parser ----
# Enable LLM fallback: when rule-based parser produces an empty structure
# (no name, no experience, no projects, no skills), automatically invoke
# LLM to re-parse. Default false (off). Enabling adds LLM call cost.
RESUME_PDF_LLM_FALLBACK=false

# ---- Docker 部署 (Optional — defaults shown) ----
# 宿主机映射端口 (docker compose 用)
REUP_PORT=5000
# 开发模式 Node Inspector 调试端口 (docker-compose.override.yml 用)
REUP_DEBUG_PORT=9229
# Compose 项目名 (多实例隔离时修改)
COMPOSE_PROJECT_NAME=reup
